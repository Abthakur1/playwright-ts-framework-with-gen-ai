{
  "name": "playwright-ts-framework",
  "version": "1.0.0",
  "description": "Playwright TypeScript test automation framework for SauceDemo",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui:chromium": "playwright test --project=uichromium",
    "test:ui:firefox": "playwright test --project=ui-firefox",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test src/tests/ui --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "typescript",
    "testing",
    "automation",
    "saucedemo"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "dotenv": "^16.0.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}